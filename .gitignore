projects/

# Firmware catalog binaries (metadata JSONs are tracked, binaries are not)
firmware-catalog/**/*.bin

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.pytest_cache/

# PlatformIO
.pio/
firmware/**/.pio/

# Node / frontend build artifacts
node_modules/
dist/
build/

# Editor
.vscode/settings.json
*.swp
*~

