# ESPAI Hub — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Docker image variant ─────────────────────────────────────────────────────
# latest   — hub + Agent Bench (Claude CLI)             ~500 MB
# workers  — + OpenCV, FFmpeg, numpy, scipy             ~900 MB
# slim     — hub only                                   ~350 MB
ESPAI_IMAGE=ghcr.io/picklepc/espai:latest

# ── Server ────────────────────────────────────────────────────────────────────
ESPAI_HOST=0.0.0.0
ESPAI_PORT=7888
ESPAI_DEBUG=0

# ── Docker: SSD mount path ────────────────────────────────────────────────────
# Path on the host where ESPAI data (projects, DB, firmware catalog) is stored.
# Common OpenWrt paths:
#   /mnt/sda1/espai          SATA/USB SSD
#   /mnt/nvme0n1p1/espai     NVMe SSD (FriendlyElec M.2 slot)
#   /opt/espai               if Docker storage is already on the SSD
ESPAI_SSD_PATH=/mnt/sda1/espai

# ── Worker dependency preloading ─────────────────────────────────────────────
# Packages here are pip-installed before the hub starts on every platform.
# Space or comma-separated.  Use the :workers Docker image to bake them in
# permanently instead of reinstalling on every restart.
#
# ESPAI_PREINSTALL=opencv-python-headless numpy scipy
#
# Alternatively, create a worker-requirements.txt next to this file
# (Docker: mount it as a volume; native: place it in ~/Documents/ESPAI/)
# and list packages in standard pip format with optional version pins.

# ── Agent Bench / Claude ──────────────────────────────────────────────────────
# Required to use the Agent Bench feature with Claude Code.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ESPAI_AGENT_BENCH=false

# ── MQTT (optional) ───────────────────────────────────────────────────────────
# Publish hub events to an MQTT broker (e.g. Mosquitto on the same router).
# ESPAI_MQTT_HOST=localhost
# ESPAI_MQTT_PORT=1883
# ESPAI_MQTT_TOPIC_PREFIX=espai
