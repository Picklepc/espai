; Copy this file to secrets.ini and fill in your credentials.
; secrets.ini is gitignored — never commit it.
;
; To use: uncomment and edit the lines below, then add to your env's build_flags:
;   build_flags = ${base.build_flags} -D WIFI_SSID=\"${sysenv.ESPAI_WIFI_SSID}\" ...
;
; Or override build_flags directly (keep this file local only):

; [secrets]
; wifi_ssid = "YourNetwork"
; wifi_pass = "YourPassword"
